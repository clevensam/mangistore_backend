# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# SUPABASE_URL: Found in Supabase Project Settings > API
SUPABASE_URL=https://your-project.supabase.co

# SUPABASE_ANON_KEY: Found in Supabase Project Settings > API
SUPABASE_ANON_KEY=your-anon-key

# SUPABASE_SERVICE_ROLE_KEY: Found in Supabase Project Settings > API (for server-side operations)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# JWT Secret for token signing (change in production!)
JWT_SECRET=your-super-secret-key-change-in-production

# Frontend URL for CORS
FRONTEND_URL=https://your-frontend.vercel.app

# Server Port
PORT=3000