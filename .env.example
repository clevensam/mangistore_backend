# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# MySQL Database URL - for local dev, set to your local MySQL connection string.
# On Railway, add DATABASE_URL = ${{MySQL.MYSQL_URL}} in the dashboard.
MYSQL_URL="mysql://root:password@localhost:3306/mangistore"

# JWT Secret for token signing (change in production!)
JWT_SECRET="your-super-secret-key-change-in-production"

# Frontend URL for CORS
FRONTEND_URL=https://your-frontend.vercel.app

# Server Port
PORT=3000
